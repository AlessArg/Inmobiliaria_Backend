Ref: marcajes.id_employee > employees.id_employee
Ref: municipalities.id_city > cities.id_city
Ref: projects.project_city_location > cities.id_city
Ref: projects.project_construction_style > construction_styles.id_construction_style
Ref: projects.project_municipality_location > municipalities.id_municipality
Ref: rejection_reasons_history.id_lead > leads.id_lead
Ref: rejection_reasons_history.id_rejection_reason > rejection_reasons.id_rejection_reason
Ref: roles_views.id_role_reference > roles.id_role
Ref: team_members.id_employee > employees.id_employee
Ref: team_members.id_team > teams.id_team
